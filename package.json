{
  "name": "fushenglu",
  "private": true,
  "version": "0.1.0",
  "description": "A local visual knowledge graph workspace for people, events, timelines, and narrative archives.",
  "author": "Tian Lutao",
  "type": "module",
  "main": "dist-electron/main.cjs",
  "scripts": {
    "dev": "concurrently -k -n api,web -c yellow,cyan \"npm:dev:api\" \"npm:dev:web\"",
    "dev:web": "vite",
    "dev:api": "tsx watch server/src/index.ts",
    "api": "tsx server/src/index.ts",
    "build": "tsc -b && tsc -p server/tsconfig.json && vite build",
    "lint": "eslint .",
    "preview": "vite preview",
    "test": "vitest run",
    "desktop:create-icon": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/create-windows-icon.ps1",
    "desktop:build-main": "esbuild electron/main.ts --bundle --platform=node --target=node22 --format=cjs --outfile=dist-electron/main.cjs --external:electron",
    "desktop:build-renderer": "cross-env VITE_DESKTOP=true VITE_API_BASE_URL=http://127.0.0.1:4177/api vite build",
    "desktop:build": "tsc -b && tsc -p server/tsconfig.json && npm run desktop:build-main && npm run desktop:build-renderer",
    "desktop:start": "electron .",
    "desktop:dev": "concurrently -k -n web,electron -c cyan,magenta \"cross-env VITE_DESKTOP=true VITE_API_BASE_URL=http://127.0.0.1:4177/api npm:dev:web\" \"wait-on http://127.0.0.1:5173 && npm run desktop:build-main && cross-env FUSHENGLU_ELECTRON_DEV_SERVER_URL=http://127.0.0.1:5173 npm run desktop:start\"",
    "desktop:dist": "npm run desktop:create-icon && npm run desktop:build && electron-builder --win nsis",
    "desktop:smoke": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/desktop-smoke.ps1",
    "release:check": "npm test && npm run desktop:dist && npm run desktop:smoke"
  },
  "build": {
    "appId": "com.fushenglu.desktop",
    "productName": "Fushenglu",
    "electronDist": "node_modules/electron/dist",
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**",
      "dist-electron/**",
      "package.json"
    ],
    "extraMetadata": {
      "main": "dist-electron/main.cjs"
    },
    "win": {
      "icon": "build/icon.ico",
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        }
      ]
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "Fushenglu"
    }
  },
  "dependencies": {
    "@dagrejs/dagre": "^3.0.0",
    "clsx": "^2.1.1",
    "cors": "^2.8.6",
    "express": "^5.2.1",
    "lucide-react": "^1.20.0",
    "react": "^19.2.6",
    "react-dom": "^19.2.6",
    "react-router-dom": "^7.18.0",
    "reactflow": "^11.11.4",
    "zod": "^4.4.3",
    "zustand": "^5.0.14"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.0",
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/node": "^24.12.3",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "autoprefixer": "^10.5.0",
    "concurrently": "^10.0.3",
    "cross-env": "^10.1.0",
    "electron": "^42.4.1",
    "electron-builder": "^26.15.3",
    "esbuild": "^0.28.1",
    "eslint": "^10.3.0",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "globals": "^17.6.0",
    "jsdom": "^27.0.1",
    "postcss": "^8.5.15",
    "tailwindcss": "^3.4.19",
    "tsx": "^4.22.4",
    "typescript": "~6.0.2",
    "typescript-eslint": "^8.59.2",
    "vite": "^8.0.12",
    "vitest": "^4.0.3",
    "wait-on": "^9.0.10"
  }
}
